# Configuración del Servidor Backend
# ===================================================================
# CONFIGURACIÓN DE BASE DE DATOS (LOCAL)
# ===================================================================
# Apuntando a tu propia computadora (localhost)
# ⚠️ IMPORTANTE: Asegúrate de que la contraseña 'admin123' sea la misma 
# que configuraste al instalar PostgreSQL en tu PC. Si tu contraseña local 
# es otra, cámbiala en la línea de abajo.
DATABASE_URL="postgresql://postgres:admin@localhost:5432/soporte_whatsapp?schema=public"

# ===================================================================
# CONFIGURACIÓN DEL SERVIDOR
# ===================================================================
PORT=3000

# ===================================================================
# SEGURIDAD
# ===================================================================
# Clave secreta para firmar los tokens JWT
JWT_SECRET="cambia_esto_por_un_string_largo_y_seguro_2026"

# ===================================================================
# OPENWA (WhatsApp Gateway)
# ===================================================================
# URL del servicio OpenWA (ajustar según tu configuración)
OPENWA_URL="http://localhost:8080"
OPENWA_API_URL="http://localhost:8080"
OPENWA_API_TOKEN="opticolor123"

# ===================================================================
# ALMACENAMIENTO DE ARCHIVOS
# ===================================================================
# Carpeta donde se guardarán los archivos multimedia
UPLOAD_DIR="./uploads"
# Tamaño máximo de archivo en MB
MAX_FILE_SIZE_MB=25