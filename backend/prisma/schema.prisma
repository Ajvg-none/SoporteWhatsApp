generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                       Int         @id @default(autoincrement())
  nombre                   String      @db.VarChar(100)
  email                    String      @unique @db.VarChar(100)
  contraseñaHash          String      @map("contraseña_hash") @db.VarChar(255)
  rol                      String      @db.VarChar(20)
  creadoEn                 DateTime?   @default(now()) @map("creado_en") @db.Timestamp(6)
  actualizadoEn            DateTime?   @default(now()) @updatedAt @map("actualizado_en") @db.Timestamp(6)
  auditoria                Auditoria[]
  mensajes                 Mensaje[]
  solicitudesTransferencia Ticket[]    @relation("SolicitudesTransferencia")
  ticketsAsignados         Ticket[]    @relation("TicketsAsignados")

  @@index([email], map: "idx_usuarios_email")
  @@index([rol], map: "idx_usuarios_rol")
  @@map("usuarios")
}

model Contacto {
  numero_telefono String    @id @db.VarChar(20)
  nombre          String?   @db.VarChar(100)
  sucursal        String?   @db.VarChar(100)
  creadoEn        DateTime? @default(now()) @map("creado_en") @db.Timestamp(6)
  actualizadoEn   DateTime? @default(now()) @updatedAt @map("actualizado_en") @db.Timestamp(6)
  tickets         Ticket[]

  @@index([nombre], map: "idx_contactos_nombre")
  @@index([sucursal], map: "idx_contactos_sucursal")
  @@map("contactos")
}

model Ticket {
  id                              Int         @id @default(autoincrement())
  numeroCliente                   String      @map("numero_cliente") @db.VarChar(20)
  estado                          String      @db.VarChar(20)
  tecnicoAsignadoId               Int?        @map("tecnico_asignado_id")
  solicitudTransferenciaTecnicoId Int?        @map("solicitud_transferencia_tecnico_id")
  transferido                     Boolean     @default(false)
  categoria                       String?     @db.VarChar(50)
  creadoEn                        DateTime?   @default(now()) @map("creado_en") @db.Timestamp(6)
  actualizadoEn                   DateTime?   @default(now()) @updatedAt @map("actualizado_en") @db.Timestamp(6)
  cerradoEn                       DateTime?   @map("cerrado_en") @db.Timestamp(6)
  auditoria                       Auditoria[]
  mensajes                        Mensaje[]
  contacto                        Contacto    @relation(fields: [numeroCliente], references: [numero_telefono])
  solicitudTransferenciaTecnico   Usuario?    @relation("SolicitudesTransferencia", fields: [solicitudTransferenciaTecnicoId], references: [id])
  tecnicoAsignado                 Usuario?    @relation("TicketsAsignados", fields: [tecnicoAsignadoId], references: [id])

  @@index([creadoEn], map: "idx_tickets_creado_en")
  @@index([estado], map: "idx_tickets_estado")
  @@index([numeroCliente], map: "idx_tickets_numero_cliente")
  @@index([solicitudTransferenciaTecnicoId], map: "idx_tickets_solicitud_transferencia")
  @@index([tecnicoAsignadoId], map: "idx_tickets_tecnico_asignado")
  @@index([transferido], map: "idx_tickets_transferido")
  @@map("tickets")
}

model Mensaje {
  id                Int       @id @default(autoincrement())
  ticketId          Int       @map("ticket_id")
  remitente         String    @db.VarChar(10)
  tecnicoId         Int?      @map("tecnico_id")
  contenido         String
  tipo              String?   @default("texto") @db.VarChar(20)
  urlAdjunto        String?   @map("url_adjunto") @db.VarChar(255)
  whatsappMessageId String    @unique @map("whatsapp_message_id") @db.VarChar(255)
  enviadoEn         DateTime? @default(now()) @map("enviado_en") @db.Timestamp(6)
  tecnico           Usuario?  @relation(fields: [tecnicoId], references: [id])
  ticket            Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([enviadoEn], map: "idx_mensajes_enviado_en")
  @@index([ticketId], map: "idx_mensajes_ticket_id")
  @@index([whatsappMessageId], map: "idx_mensajes_whatsapp_id")
  @@map("mensajes")
}

model Auditoria {
  id        Int       @id @default(autoincrement())
  ticketId  Int       @map("ticket_id")
  usuarioId Int       @map("usuario_id")
  accion    String    @db.VarChar(50)
  detalle   Json?
  fechaHora DateTime? @default(now()) @map("fecha_hora") @db.Timestamp(6)
  ticket    Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  usuario   Usuario   @relation(fields: [usuarioId], references: [id])

  @@index([fechaHora], map: "idx_auditoria_fecha_hora")
  @@index([ticketId], map: "idx_auditoria_ticket_id")
  @@index([usuarioId], map: "idx_auditoria_usuario_id")
  @@map("auditoria")
}
